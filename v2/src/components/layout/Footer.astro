---
import Logo from "../ui/Logo.astro";

interface FooterLink {
  href: string;
  label: string;
}

const quickLinks: FooterLink[] = [
  { href: "#inicio", label: "Inicio" },
  { href: "#sobre-mi", label: "Sobre mí" },
  { href: "#skills", label: "Skills" },
  { href: "#proyectos", label: "Proyectos" },
  { href: "#contacto", label: "Contacto" },
];
---

<!-- [ASTRO: Footer.astro] -->
<footer class="footer-root border-t" aria-label="Pie de página del portfolio">
  <div
    class="mx-auto grid w-full max-w-6xl gap-6 px-5 py-8 md:px-8 lg:grid-cols-[1fr_auto_1fr] lg:items-center"
  >
    <p
      class="footer-copy text-center font-mono text-xs tracking-[0.04em] lg:text-left"
    >
      built with <span class="grad-text font-bold">&lt;determination /&gt;</span
      > by Azael Reyes © 2026
    </p>

    <a
      href="#inicio"
      class="footer-logo-link mx-auto inline-flex items-center justify-center transition-transform duration-300 hover:scale-110"
      aria-label="Volver al inicio"
    >
      <Logo className="scale-125" showDevLabel={false} />
    </a>

    <nav
      aria-label="Navegación rápida del pie"
      class="flex flex-wrap items-center justify-center gap-x-4 gap-y-2 lg:justify-end"
    >
      {
        quickLinks.map((item) => (
          <a
            href={item.href}
            class="footer-nav-link font-body text-xs font-medium transition-colors duration-200 hover:text-sky"
          >
            {item.label}
          </a>
        ))
      }
    </nav>
  </div>
</footer>

<style>
  /* ── Dark mode (default) ── */
  .footer-root {
    background: var(--surf);
    border-top-color: var(--border);
  }

  .footer-copy {
    color: var(--muted);
  }

  .footer-logo-link {
    /* no background, no border — logo floats transparently */
  }

  .footer-logo-link:hover {
    opacity: 0.85;
  }

  .footer-nav-link {
    color: var(--muted);
  }

  .footer-nav-link:hover {
    color: var(--sky);
  }

  /* ── Light mode ── */
  :global([data-theme="light"]) .footer-root {
    background: var(--surf);
    border-top-color: var(--border);
  }

  :global([data-theme="light"]) .footer-copy {
    color: var(--muted);
  }

  :global([data-theme="light"]) .footer-logo-link {
    /* transparent — no background artifact */
  }

  :global([data-theme="light"]) .footer-logo-link:hover {
    opacity: 0.8;
  }

  :global([data-theme="light"]) .footer-nav-link {
    color: var(--muted);
  }
</style>
