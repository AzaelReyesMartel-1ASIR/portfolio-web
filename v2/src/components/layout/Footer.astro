---
import Logo from "../ui/Logo.astro";
import { getLangFromUrl, useTranslations } from "../../i18n/utils";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

interface FooterLink {
  href: string;
  label: string;
}

const quickLinks: FooterLink[] = [
  { href: `/${lang === 'es' ? '' : lang + '/'}#inicio`, label: t('nav.home') },
  { href: `/${lang === 'es' ? '' : lang + '/'}#sobre-mi`, label: t('nav.about') },
  { href: `/${lang === 'es' ? '' : lang + '/'}#skills`, label: t('nav.skills') },
  { href: `/${lang === 'es' ? '' : lang + '/'}#proyectos`, label: t('nav.projects') },
  { href: `/${lang === 'es' ? '' : lang + '/'}#contacto`, label: t('nav.contact') },
];
---

<!-- [ASTRO: Footer.astro] -->
<footer class="footer-root border-t" aria-label={t('footer.aria')}>
  <div
    class="mx-auto grid w-full max-w-6xl gap-6 px-5 py-8 md:px-8 lg:grid-cols-[1fr_auto_1fr] lg:items-center"
  >
    <div class="flex flex-col gap-1.5 text-center lg:text-left">
      <p class="footer-copy font-mono text-xs tracking-[0.04em]">
        {t('footer.built')} <span class="grad-text font-bold">&lt;determination /&gt;</span> {t('footer.by')}
      </p>
      <a 
        href={`/${lang === 'es' ? '' : lang + '/'}legal`}
        class="font-mono text-[10px] text-slate-400 dark:text-slate-300 hover:text-sky transition-all duration-200 tracking-wide border-b border-transparent hover:border-current pb-[1px] w-fit mx-auto lg:mx-0"
      >
        {t('footer.legal')}
      </a>
    </div>

    <a
      href={`/${lang === 'es' ? '' : lang + '/'}#inicio`}
      class="footer-logo-link mx-auto inline-flex items-center justify-center bg-transparent transition-transform duration-300 hover:scale-110"
      aria-label={t('footer.back')}
    >
      <Logo className="scale-125" showDevLabel={false} />
    </a>

    <nav
      aria-label="Navegación rápida del pie"
      class="flex flex-wrap items-center justify-center gap-x-4 gap-y-2 lg:justify-end"
    >
      {
        quickLinks.map((item) => (
          <a
            href={item.href}
            class="footer-nav-link font-body text-xs font-medium transition-colors duration-200 hover:text-sky"
          >
            {item.label}
          </a>
        ))
      }
    </nav>
  </div>
</footer>

<style>
  /* ── Dark mode (default) ── */
  .footer-root {
    background: var(--surf);
    border-top-color: var(--border);
  }

  .footer-copy {
    color: var(--muted);
  }

  .footer-logo-link {
    /* no background, no border — logo floats transparently */
  }

  .footer-logo-link:hover {
    opacity: 0.85;
  }

  .footer-nav-link {
    color: var(--muted);
  }

  .footer-nav-link:hover {
    color: var(--sky);
  }

  /* ── Light mode ── */
  :global([data-theme="light"]) .footer-root {
    background: var(--surf);
    border-top-color: var(--border);
  }

  :global([data-theme="light"]) .footer-copy {
    color: var(--muted);
  }

  :global([data-theme="light"]) .footer-logo-link {
    /* transparent — no background artifact */
  }

  :global([data-theme="light"]) .footer-logo-link:hover {
    opacity: 0.8;
  }

  :global([data-theme="light"]) .footer-nav-link {
    color: var(--muted);
  }
</style>
