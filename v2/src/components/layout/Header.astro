---
import Logo from "../ui/Logo.astro";

interface NavItem {
  href: string;
  label: string;
}

const navItems: NavItem[] = [
  { href: "#inicio", label: "Inicio" },
  { href: "#sobre-mi", label: "Sobre mí" },
  { href: "#skills", label: "Skills" },
  { href: "#proyectos", label: "Proyectos" },
  { href: "#contacto", label: "Contacto" },
];
---

<!-- [ASTRO: Header.astro] -->
<div
  id="scroll-bar"
  class="pointer-events-none fixed top-0 z-[2000] h-[2px] w-0 bg-gradient-to-r from-sky to-violet transition-[width] duration-150"
  aria-hidden="true"
></div>

<header
  id="site-header"
  class="fixed left-0 top-0 z-[1000] w-full border-b border-transparent bg-transparent transition-all duration-300 ease-in-out"
  aria-label="Cabecera principal"
>
  <div class="mx-auto flex h-18 w-full max-w-6xl items-center justify-between gap-4 px-5 md:px-8">
    <a
      href="#inicio"
      class="inline-flex items-center"
      aria-label="Ir al inicio"
    >
      <Logo className="shrink-0" />
    </a>

    <nav
      aria-label="Navegación principal"
      class="hidden items-center gap-6 lg:flex"
    >
      {
        navItems.map((item) => (
          <a
            href={item.href}
            class="header-link relative font-body text-sm font-medium text-ink/90 transition-colors duration-200 hover:text-sky"
          >
            {item.label}
          </a>
        ))
      }
    </nav>

    <div class="flex items-center gap-2">
      <button
        type="button"
        id="theme-toggle"
        class="inline-flex h-10 w-10 items-center justify-center rounded-full border border-white/10 bg-card/80 text-muted transition-colors duration-200 hover:border-sky/35 hover:text-sky"
        aria-label="Cambiar tema"
      >
        <span aria-hidden="true" class="font-mono text-sm">◐</span>
      </button>

      <button
        type="button"
        id="menu-toggle"
        class="inline-flex h-10 w-10 items-center justify-center rounded-full border border-white/10 bg-card/80 text-ink transition-colors duration-200 hover:border-sky/35 hover:text-sky lg:hidden"
        aria-label="Abrir menú de navegación"
        aria-controls="mobile-menu"
        aria-expanded="false"
      >
        <span class="sr-only">Abrir menú</span>
        <span aria-hidden="true" class="font-mono text-lg">≡</span>
      </button>
    </div>
  </div>

  <nav
    id="mobile-menu"
    aria-label="Navegación móvil"
    data-open="false"
    class="max-h-0 overflow-hidden border-t border-transparent bg-surf/95 opacity-0 backdrop-blur-xl transition-all duration-300 ease-in-out lg:hidden"
  >
    <ul class="mx-auto flex w-full max-w-6xl flex-col gap-1 px-5 py-3 md:px-8">
      {
        navItems.map((item) => (
          <li>
            <a
              href={item.href}
              class="inline-flex w-full rounded-xl px-3 py-2 font-body text-sm font-medium text-ink/90 transition-colors duration-200 hover:bg-white/5 hover:text-sky"
            >
              {item.label}
            </a>
          </li>
        ))
      }
    </ul>
  </nav>
</header>

<style>
  #site-header.scrolled {
    background: rgba(4, 8, 26, 0.88);
    backdrop-filter: blur(20px);
    border-bottom-color: var(--border);
  }

  .header-link::after {
    content: "";
    position: absolute;
    left: 0;
    bottom: -0.25rem;
    width: 0;
    height: 1.5px;
    background: linear-gradient(90deg, var(--sky), var(--violet));
    transition: width 0.25s ease;
  }

  .header-link:hover::after,
  .header-link:focus-visible::after {
    width: 100%;
  }

  #mobile-menu[data-open="true"] {
    max-height: 18rem;
    border-top-color: var(--border);
    opacity: 1;
  }
</style>
