---
import { TIMELINE_ITEMS, type TimelineItem } from "../../data/timeline";
import { getLangFromUrl, useTranslations } from "../../i18n/utils";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

interface Props {}

const {} = Astro.props as Props;

const featuredTimeline: readonly TimelineItem[] = TIMELINE_ITEMS.filter(
  (item) =>
    item.nodeType === "experience" ||
    item.id === "asir-2022-2024" ||
    item.id === "daw-2024-2026",
);
---

<!-- [ASTRO: About.astro] -->
<section
  id="sobre-mi"
  aria-label={t('about.aria')}
  class="px-6 py-28 md:px-10 lg:px-14"
>
  <div class="mx-auto w-full max-w-6xl">
    <div class="mb-10 space-y-4">
      <p
        class="font-mono text-[0.72rem] uppercase tracking-[0.18em] text-sky reveal"
      >
        {t('about.label')}
      </p>
      <h2
        class="max-w-4xl font-display text-[clamp(1.8rem,4vw,2.5rem)] leading-tight text-ink reveal rd1"
      >
        {t('about.heading')}
        <span class="grad-text">{t('about.heading.em')}</span>
      </h2>
    </div>

    <div class="about-bento-grid">
      <article
        class="about-bento-card bento-bio reveal rd1"
        aria-label={t('about.bio.aria')}
      >
        <h3 class="font-display text-xl text-ink">
          {t('about.bio.title')}
        </h3>
        <div class="mt-5 space-y-4 text-[0.96rem] leading-7 text-muted">
          <p class="reveal rd1">
            {t('about.bio.p1')}
          </p>
          <p class="reveal rd2">
            {t('about.bio.p2')}
          </p>
          <p class="reveal rd3">
            {t('about.bio.p3')}
          </p>
        </div>
      </article>

      <article
        class="about-bento-card bento-stats reveal rd2"
        aria-label={t('about.stats.aria')}
      >
        <h3 class="font-display text-lg text-ink">{t('about.stats.title')}</h3>
        <div class="mt-5 grid grid-cols-2 gap-3">
          <div class="stat-tile">
            <p class="font-display text-3xl text-sky">
              <span
                class="js-counter"
                data-target="3"
                data-prefix=""
                data-suffix="+">3+</span
              >
            </p>
            <p
              class="mt-1 font-mono text-[0.72rem] uppercase tracking-wide text-muted"
            >
              {t('about.stats.projects')}
            </p>
          </div>
          <div class="stat-tile">
            <p class="font-display text-3xl text-violet">
              <span
                class="js-counter"
                data-target="2"
                data-prefix=""
                data-suffix="">2</span
              >
            </p>
            <p
              class="mt-1 font-mono text-[0.72rem] uppercase tracking-wide text-muted"
            >
              {t('about.stats.degrees')}
            </p>
          </div>
          <div class="stat-tile">
            <p class="font-display text-3xl text-green">
              <span
                class="js-counter"
                data-target="100"
                data-prefix=""
                data-suffix="%">100%</span
              >
            </p>
            <p
              class="mt-1 font-mono text-[0.72rem] uppercase tracking-wide text-muted"
            >
              {t('about.stats.commitment')}
            </p>
          </div>
          <div class="stat-tile">
            <p class="font-display text-3xl text-orange">{t('about.stats.coffee.val')}</p>
            <p
              class="mt-1 font-mono text-[0.72rem] uppercase tracking-wide text-muted"
            >
              {t('about.stats.coffee')}
            </p>
          </div>
        </div>
      </article>

      <article
        class="about-bento-card bento-focus reveal rd2"
        aria-label={t('about.focus.aria')}
      >
        <h3 class="font-display text-lg text-ink">{t('about.focus.title')}</h3>
        <ul class="mt-5 space-y-3 text-sm text-muted">
          <li class="focus-item">
            <span
              class="focus-dot bg-sky shadow-[0_0_10px_rgba(56,189,248,0.55)]"
            ></span>
            {t('about.focus.li1')}
          </li>
          <li class="focus-item">
            <span
              class="focus-dot bg-violet shadow-[0_0_10px_rgba(167,139,250,0.55)]"
            ></span>
            {t('about.focus.li2')}
          </li>
          <li class="focus-item">
            <span
              class="focus-dot bg-green shadow-[0_0_10px_rgba(52,211,153,0.55)]"
            ></span>
            {t('about.focus.li3')}
          </li>
        </ul>
      </article>

      <article
        class="about-bento-card bento-timeline reveal rd3"
        aria-label={t('about.timeline.aria')}
      >
        <h3 class="font-display text-lg text-ink">{t('about.timeline.title')}</h3>
        <div class="timeline-container mt-5">
          {
            featuredTimeline.map((item) => (
              <div class="timeline-row">
                <span class="timeline-dot" />
                <p class="flex items-center font-mono text-[0.72rem] uppercase tracking-wide text-sky">
                  {item.id === "certifications-active" ? t('timeline.certifications-active.yearLabel') : item.yearLabel}
                  <svg
                    class="rezero-timeline-clock ml-2 inline-block h-3.5 w-3.5 text-violet opacity-70"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="1.5"
                    stroke-dasharray="2 3"
                    aria-hidden="true"
                  >
                    <circle cx="12" cy="12" r="9" />
                    <line x1="12" y1="12" x2="12" y2="6" />
                  </svg>
                </p>
                <p class="mt-1 text-sm font-semibold text-ink">{t(`timeline.${item.id}.role` as any)}</p>
                <p class="text-xs text-muted">
                  {(item.organization === "CIFP Villa de Agüimes" || item.organization === "Bitbox SL" || item.organization === "Empire Systems" || item.organization === "Cloud Canary Services") ? item.organization : t(`timeline.${item.id}.organization` as any)} · {t(`timeline.${item.id}.period` as any)}
                </p>
                {item.details.length > 0 && (
                  <ul class="mt-2 flex flex-wrap gap-2">
                    {item.details.slice(0, 3).map((_detail, dIndex) => (
                      <li class="rounded-full border border-white/10 bg-white/5 px-2.5 py-1 font-mono text-[0.68rem] text-muted">
                        {t(`timeline.${item.id}.detail.${dIndex}` as any)}
                      </li>
                    ))}
                  </ul>
                )}
              </div>
            ))
          }
        </div>
      </article>
    </div>
  </div>
</section>

<style>
  .about-bento-grid {
    display: grid;
    gap: 1rem;
    grid-template-columns: minmax(0, 1.25fr) minmax(0, 1fr) minmax(0, 1fr);
    grid-template-areas:
      "bio bio stats"
      "focus timeline timeline";
  }

  .about-bento-card {
    border: 1px solid var(--border);
    border-radius: 20px;
    background: rgba(12, 21, 48, 0.72);
    padding: 1.25rem;
    backdrop-filter: blur(8px);
  }

  .bento-bio {
    grid-area: bio;
  }

  .bento-stats {
    grid-area: stats;
  }

  .bento-focus {
    grid-area: focus;
  }

  .bento-timeline {
    grid-area: timeline;
  }

  .stat-tile {
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 14px;
    background: rgba(255, 255, 255, 0.02);
    padding: 0.75rem;
    min-height: 90px;
  }

  .focus-item {
    display: flex;
    align-items: flex-start;
    gap: 0.625rem;
    line-height: 1.45;
  }

  .focus-dot {
    margin-top: 0.32rem;
    width: 0.42rem;
    height: 0.42rem;
    border-radius: 999px;
    flex-shrink: 0;
  }

  /* ── git-log timeline ── */
  .timeline-container {
    position: relative;
    padding-left: 1.75rem;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  /* Vertical gradient line anchored to container */
  .timeline-container::before {
    content: "";
    position: absolute;
    left: 5px;
    top: 12px;
    bottom: 12px;
    width: 1.5px;
    background: linear-gradient(
      to bottom,
      var(--sky),
      var(--violet),
      transparent
    );
    border-radius: 99px;
  }

  .timeline-row {
    position: relative;
    border: 1px solid rgba(255, 255, 255, 0.06);
    border-radius: 14px;
    background: rgba(4, 8, 26, 0.45);
    padding: 0.8rem 0.8rem 0.8rem 0.9rem;
    transition: border-color 0.22s ease;
  }

  .timeline-row:hover {
    border-color: rgba(56, 189, 248, 0.28);
  }

  /* Dot that sits on the vertical line */
  .timeline-dot {
    position: absolute;
    left: -1.65rem;
    top: 0.85rem;
    width: 9px;
    height: 9px;
    border-radius: 50%;
    background: var(--bg, #04081a);
    border: 2px solid var(--sky);
    box-shadow: 0 0 6px rgba(56, 189, 248, 0.55);
    z-index: 2;
    transition: box-shadow 0.22s ease;
  }

  .timeline-row:hover .timeline-dot {
    box-shadow: 0 0 12px rgba(56, 189, 248, 0.85);
  }

  @media (max-width: 1080px) {
    .about-bento-grid {
      grid-template-columns: 1fr 1fr;
      grid-template-areas:
        "bio bio"
        "stats focus"
        "timeline timeline";
    }
  }

  @media (max-width: 768px) {
    .about-bento-grid {
      grid-template-columns: 1fr;
      grid-template-areas:
        "bio"
        "stats"
        "focus"
        "timeline";
    }
  }

  /* ── Light mode overrides ── */
  :global([data-theme="light"]) .about-bento-card {
    background: #ffffff;
    border-color: rgba(0, 0, 0, 0.09);
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.07);
    backdrop-filter: none;
  }

  :global([data-theme="light"]) .stat-tile {
    background: rgba(0, 0, 0, 0.025);
    border-color: rgba(0, 0, 0, 0.07);
  }

  :global([data-theme="light"]) .timeline-row {
    background: rgba(248, 249, 253, 0.95);
    border-color: rgba(0, 0, 0, 0.07);
  }

  :global([data-theme="light"]) .timeline-dot {
    background: var(--surf);
  }
  /* ── TAREA 4: Re:Zero clock ── */
  @keyframes rewind-time {
    from {
      transform: rotate(0deg);
    }
    to {
      transform: rotate(-360deg);
    }
  }

  .rezero-timeline-clock {
    transform-origin: center;
    animation: rewind-time 8s linear infinite;
    flex-shrink: 0;
  }
</style>
