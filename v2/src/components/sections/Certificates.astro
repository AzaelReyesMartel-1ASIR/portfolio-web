    issuer: "OpenWebinars",
    date: "2024",
    accent: "violet",
    imageUrl: "/cert/azael_certificado_creando_un_crud_con_php_mysql_html_css_y_javascript.webp",
    verificationUrl: "/cert/azael_certificado_creando_un_crud_con_php_mysql_html_css_y_javascript.webp",
