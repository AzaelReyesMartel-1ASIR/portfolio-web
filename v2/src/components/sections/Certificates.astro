  },
  {
    id: "datacamp-python",
    title: t('certificates.datacamp.python' as any),
    issuer: "DataCamp",
    date: "2026",
    accent: "sky",
    verificationUrl: "https://www.datacamp.com/completed/statement-of-accomplishment/track/d829fc4589406624dd94dbf63428a459b5b23421?utm_medium=organic_social&utm_campaign=sharewidget&utm_content=soa",
    imageUrl: "/cert/PythonCert.webp",
    category: "datacamp",
    featured: true,
    images: ["/cert/PythonCert.webp"],
    externalUrl: "https://www.datacamp.com/completed/statement-of-accomplishment/track/d829fc4589406624dd94dbf63428a459b5b23421?utm_medium=organic_social&utm_campaign=sharewidget&utm_content=soa",
  },
  {
    id: "datacamp-openai",
    title: t('certificates.datacamp.openai' as any),
    issuer: "DataCamp",
    date: "2026",
    accent: "green",
    verificationUrl: "https://www.datacamp.com/completed/statement-of-accomplishment/course/08394fa2b470b2171147dbe229ed4439cbb905e1?utm_medium=organic_social&utm_campaign=sharewidget&utm_content=soa",
    imageUrl: "/cert/WorkingWopenaiAPI.webp",
    category: "datacamp",
    featured: true,
    images: ["/cert/WorkingWopenaiAPI.webp"],
    externalUrl: "https://www.datacamp.com/completed/statement-of-accomplishment/course/08394fa2b470b2171147dbe229ed4439cbb905e1?utm_medium=organic_social&utm_campaign=sharewidget&utm_content=soa",
  },
  {
    id: "ow-bash-fund",
    title: t('certificates.ow.bash-fund' as any),
    issuer: "OpenWebinars",
    date: "2023",
    accent: "sky",
    imageUrl: "/cert/azael_certificado_fundamentos_de_scripting_en_bash.webp",
    verificationUrl: "/cert/azael_certificado_fundamentos_de_scripting_en_bash.webp",
    category: "ow",
    featured: false,
    images: ["/cert/azael_certificado_fundamentos_de_scripting_en_bash.webp"],
  },
  {
    id: "ow-bash-proc",
    title: t('certificates.ow.bash-proc' as any),
    issuer: "OpenWebinars",
    date: "2023",
    accent: "violet",
    imageUrl: "/cert/azael_certificado_curso_de_bash_scripting_y_automatización_de_procesos.webp",
    verificationUrl: "/cert/azael_certificado_curso_de_bash_scripting_y_automatización_de_procesos.webp",
    category: "ow",
    featured: true,
    images: ["/cert/azael_certificado_curso_de_bash_scripting_y_automatización_de_procesos.webp"],
  },
  {
    id: "ow-powershell",
    title: t('certificates.ow.powershell' as any),
    issuer: "OpenWebinars",
    date: "2023",
    accent: "green",
