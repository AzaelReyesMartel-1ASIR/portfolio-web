---
import { getLangFromUrl, useTranslations } from "../../i18n/utils";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

interface CertificateItem {
  id: string;
  title: string;
  issuer: string;
  date: string;
  accent: "sky" | "violet" | "green";
  verificationUrl?: string;
  imageUrl?: string;
  category: "cfgs" | "datacamp" | "ow";
  featured: boolean;
  images: string[];
  externalUrl?: string;
}

const certificates: CertificateItem[] = [
  {
    id: "asir",
    title: t('timeline.asir-2022-2024.role' as any),
    issuer: "CIFP Villa de Agüimes",
    date: "2024",
    accent: "sky",
    imageUrl: "/cert/CFGS_certs/Cert.ASIR.azael/azael-tituloASIR.webp",
    verificationUrl: "/cert/CFGS_certs/Cert.ASIR.azael/azael-tituloASIR.webp",
    category: "cfgs",
    featured: true,
    images: ["/cert/CFGS_certs/Cert.ASIR.azael/azael-tituloASIR.webp"],
  },
  {
    id: "daw",
    title: t('timeline.daw-2024-2026.role' as any),
    issuer: "CIFP Villa de Agüimes",
    date: "2026",
    accent: "violet",
    imageUrl: "/cert/CFGS_certs/Cert.DAW.azael/CertificadoDAW Azael_page-0001.webp",
    verificationUrl: "/cert/CFGS_certs/Cert.DAW.azael/CertificadoDAW Azael_page-0001.webp",
    category: "cfgs",
    featured: true,
    images: [
      "/cert/CFGS_certs/Cert.DAW.azael/CertificadoDAW Azael_page-0001.webp",
      "/cert/CFGS_certs/Cert.DAW.azael/CertificadoDAW Azael_page-0002.webp"
