---
import BentoCard from "../ui/BentoCard.astro";
import { SKILL_GROUPS, type SkillGroup } from "../../data/skills";
import { getLangFromUrl, useTranslations } from "../../i18n/utils";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

interface Props {}

const {} = Astro.props as Props;

const groupMap: Record<SkillGroup["id"], SkillGroup> = SKILL_GROUPS.reduce(
  (accumulator, group) => {
    accumulator[group.id] = group;
    return accumulator;
  },
  {} as Record<SkillGroup["id"], SkillGroup>,
);

const systemsDevops: SkillGroup = groupMap["systems-devops"];
const backendDb: SkillGroup = groupMap["backend-db"];
const frontendUi: SkillGroup = groupMap["frontend-ui"];
const networkSecurity: SkillGroup = groupMap["network-security"];
---

<!-- [ASTRO: Skills.astro] -->
<section
  id="skills"
  aria-label={t('skills.aria')}
  class="px-6 py-28 md:px-10 lg:px-14"
>
  <div class="mx-auto w-full max-w-6xl">
    <div class="mb-10 space-y-4">
      <p
        class="font-mono text-[0.72rem] uppercase tracking-[0.18em] text-sky reveal"
      >
        {t('skills.label')}
      </p>
      <h2
        class="max-w-4xl font-display text-[clamp(1.8rem,4vw,2.5rem)] leading-tight text-ink reveal rd1"
      >
        {t('skills.heading')}
        <span class="grad-text">{t('skills.heading.em')}</span>
      </h2>
    </div>

    <div class="skills-bento-grid">
      <BentoCard
        title={t('skills.title.systems')}
        accent={systemsDevops.accent}
        tags={systemsDevops.tags}
        bars={systemsDevops.bars}
        areaClass="skills-systems"
        revealDelayClass="rd1"
      />
      <BentoCard
        title={t('skills.title.backend')}
        accent={backendDb.accent}
        tags={backendDb.tags}
        areaClass="skills-backend"
        revealDelayClass="rd2"
      />
      <BentoCard
        title={t('skills.title.frontend')}
        accent={frontendUi.accent}
        tags={frontendUi.tags}
        areaClass="skills-frontend"
        revealDelayClass="rd3"
      />
      <BentoCard
        title={t('skills.title.network')}
        accent={networkSecurity.accent}
        tags={networkSecurity.tags}
        areaClass="skills-network"
        revealDelayClass="rd4"
      />
    </div>
  </div>
</section>

<style>
  .skills-bento-grid {
    display: grid;
    gap: 1rem;
    grid-template-columns: minmax(0, 1.35fr) minmax(0, 1fr) minmax(0, 1fr);
    grid-template-areas:
      "systems backend frontend"
      "systems network network";
  }

  .skills-systems {
    grid-area: systems;
  }

  .skills-backend {
    grid-area: backend;
  }

  .skills-frontend {
    grid-area: frontend;
  }

  .skills-network {
    grid-area: network;
  }

  @media (max-width: 1080px) {
    .skills-bento-grid {
      grid-template-columns: 1fr 1fr;
      grid-template-areas:
        "systems systems"
        "backend frontend"
        "network network";
    }
  }

  @media (max-width: 768px) {
    .skills-bento-grid {
      grid-template-columns: 1fr;
      grid-template-areas:
        "systems"
        "backend"
        "frontend"
        "network";
    }
  }
</style>
