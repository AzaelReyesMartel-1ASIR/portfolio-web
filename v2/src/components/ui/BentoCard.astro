---
import type { SkillAccent, SkillBar } from "../../data/skills";

interface Props {
  title: string;
  accent: SkillAccent;
  tags: readonly string[];
  bars?: readonly SkillBar[];
  areaClass?: string;
  revealDelayClass?: "rd1" | "rd2" | "rd3" | "rd4";
}

const {
  title,
  accent,
  tags,
  bars = [],
  areaClass = "",
  revealDelayClass = "rd1",
} = Astro.props as Props;

const accentClassMap: Record<SkillAccent, string> = {
  sky: "bento-accent-sky",
  violet: "bento-accent-violet",
  green: "bento-accent-green",
  orange: "bento-accent-orange",
};

const hasBars: boolean = bars.length > 0;
---

<!-- [ASTRO: BentoCard.astro] -->
<article
  class={`skills-bento-card card-hover spt reveal ${revealDelayClass} ${accentClassMap[accent]} ${areaClass}`}
  aria-label={`Tarjeta de habilidades ${title}`}
>
  <div class="mb-4 flex items-center justify-between gap-3">
    <h3 class="font-display text-xl" style="color: var(--ink)">{title}</h3>
    <span class="font-mono text-[0.68rem] uppercase tracking-[0.18em] text-muted">stack</span>
  </div>

  {hasBars ? (
    <ul class="skill-bars" aria-label={`Niveles de dominio para ${title}`}>
      {bars.map((bar, index) => (
        <li class="skill-bar-row" style={`--bar-value:${bar.value}%; --bar-order:${index};`}>
          <div class="mb-2 flex items-center justify-between gap-3">
            <span class="font-mono text-[0.72rem] uppercase tracking-[0.08em]" style="color: var(--ink)">{bar.label}</span>
            <span class="font-mono text-[0.68rem]" style="color: var(--sky)">{bar.value}%</span>
          </div>
          <div class="skill-progress-track" aria-hidden="true">
            <span class="skill-progress-fill" style="--target-width: var(--bar-value)"></span>
          </div>
        </li>
      ))}
    </ul>
  ) : (
    <ul class="flex flex-wrap gap-2" aria-label={`Tecnologías incluidas en ${title}`}>
      {tags.map((tag) => (
        <li class="skill-tag">{tag}</li>
      ))}
    </ul>
  )}

  {hasBars && (
    <ul class="mt-5 flex flex-wrap gap-2" aria-label={`Tecnologías complementarias de ${title}`}>
      {tags.map((tag) => (
        <li class="skill-tag">{tag}</li>
      ))}
    </ul>
  )}
</article>

<style>
  .skills-bento-card {
    position: relative;
    overflow: hidden;
    border: 1px solid var(--border);
    border-radius: 20px;
    background: rgba(12, 21, 48, 0.74);
    padding: 1.25rem;
    backdrop-filter: blur(8px);
    isolation: isolate;
  }

  .skills-bento-card::before {
    content: "";
    position: absolute;
    inset: 0;
    z-index: 0;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.24s ease;
    background: radial-gradient(
      320px circle at var(--spot-x, 50%) var(--spot-y, 50%),
      rgba(255, 255, 255, 0.16),
      transparent 65%
    );
  }

  .skills-bento-card:hover::before {
    opacity: 1;
  }

  .skills-bento-card > * {
    position: relative;
    z-index: 1;
  }

  .skill-tag {
    border: 1px solid var(--border);
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.03);
    padding: 0.3rem 0.62rem;
    font-family: var(--font-mono);
    font-size: 0.68rem;
    color: var(--muted);
    transition: color 0.2s ease, border-color 0.2s ease;
  }

  .skill-bars {
    display: grid;
    gap: 0.68rem;
  }

  .skill-bar-row {
    border: 1px solid rgba(255, 255, 255, 0.07);
    border-radius: 12px;
    background: rgba(4, 8, 26, 0.52);
    padding: 0.62rem;
  }

  .skill-progress-track {
    overflow: hidden;
    height: 7px;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.1);
  }

  .skill-progress-fill {
    display: block;
    width: var(--bar-value);
    height: 100%;
    border-radius: 999px;
    transform-origin: left;
    transform: scaleX(0);
    opacity: 0.95;
  }

  .skills-bento-card.vis .skill-progress-fill {
    animation: skillBarGrow 0.8s ease forwards;
    animation-delay: calc(var(--bar-order) * 110ms);
  }

  .bento-accent-sky {
    border-color: rgba(56, 189, 248, 0.22);
  }

  .bento-accent-sky .skill-progress-fill {
    background: linear-gradient(90deg, rgba(56, 189, 248, 0.78), rgba(56, 189, 248, 1));
  }

  .bento-accent-violet {
    border-color: rgba(167, 139, 250, 0.24);
  }

  .bento-accent-violet .skill-progress-fill {
    background: linear-gradient(90deg, rgba(167, 139, 250, 0.78), rgba(167, 139, 250, 1));
  }

  .bento-accent-green {
    border-color: rgba(52, 211, 153, 0.24);
  }

  .bento-accent-green .skill-progress-fill {
    background: linear-gradient(90deg, rgba(52, 211, 153, 0.78), rgba(52, 211, 153, 1));
  }

  .bento-accent-orange {
    border-color: rgba(251, 146, 60, 0.24);
  }

  .bento-accent-orange .skill-progress-fill {
    background: linear-gradient(90deg, rgba(251, 146, 60, 0.78), rgba(251, 146, 60, 1));
  }

  @keyframes skillBarGrow {
    to {
      transform: scaleX(1);
    }
  }

  /* ── TAREA 3: SAO HP Drain animation on card hover ── */
  @keyframes hpDrain {
    0%   { width: 100%;                background-color: #f97316; transform: scaleX(1); }
    40%  { width: var(--target-width);  background-color: #f97316; transform: scaleX(1); }
    100% { width: var(--target-width);  background-color: var(--sky); transform: scaleX(1); }
  }

  /* Reset to normal grow when card is NOT hovered */
  .skills-bento-card.vis .skill-progress-fill {
    animation: skillBarGrow 0.8s ease forwards;
    animation-delay: calc(var(--bar-order) * 110ms);
  }

  /* HP drain override on card hover */
  .skills-bento-card:hover .skill-progress-fill {
    transform: scaleX(1); /* cancel scaleX mid-animation */
    animation: hpDrain 0.8s ease-out forwards;
    animation-delay: calc(var(--bar-order) * 80ms);
  }

  /* ── Light mode ── */
  :global([data-theme="light"]) .skills-bento-card {
    background: #ffffff;
    border-color: rgba(0, 0, 0, 0.09);
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.07);
  }

  :global([data-theme="light"]) .skills-bento-card::before {
    background: radial-gradient(
      320px circle at var(--spot-x, 50%) var(--spot-y, 50%),
      rgba(14, 165, 233, 0.08),
      transparent 65%
    );
  }

  :global([data-theme="light"]) .skill-tag {
    border-color: rgba(0, 0, 0, 0.1);
    background: rgba(0, 0, 0, 0.03);
    color: var(--muted);
  }

  :global([data-theme="light"]) .skill-bar-row {
    background: rgba(0, 0, 0, 0.03);
    border-color: rgba(0, 0, 0, 0.07);
  }

  :global([data-theme="light"]) .skill-progress-track {
    background: rgba(0, 0, 0, 0.08);
  }

  :global([data-theme="light"]) .bento-accent-sky    { border-color: rgba(14, 165, 233, 0.35); }
  :global([data-theme="light"]) .bento-accent-violet { border-color: rgba(124, 58, 237, 0.3);  }
  :global([data-theme="light"]) .bento-accent-green  { border-color: rgba(5, 150, 105, 0.3);   }
  :global([data-theme="light"]) .bento-accent-orange { border-color: rgba(234, 88, 12, 0.3);   }
</style>
