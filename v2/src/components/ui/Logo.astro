---
// [ASTRO: Logo.astro] — Hexagon + terminal >_ (clean, zero artifacts)
interface Props {
  className?: string;
  ariaLabel?: string;
  showDevLabel?: boolean;
}

const {
  className = "",
  ariaLabel = "Logo de Azael Reyes",
  showDevLabel = true,
} = Astro.props;
---

<!-- [ASTRO: Logo.astro] -->
<span
  class={`logo-root group relative inline-flex items-center gap-2 ${className}`}
  aria-label={ariaLabel}
>
  <svg
    xmlns="http://www.w3.org/2000/svg"
    viewBox="0 0 24 24"
    role="img"
    aria-hidden="true"
    class="logo-svg glitch-svg h-[28px] w-[28px] overflow-visible bg-transparent"
  >
    <defs>
      <linearGradient id="logo-grad" x1="0%" y1="0%" x2="100%" y2="100%">
        <stop offset="0%"   stop-color="var(--sky)"    />
        <stop offset="100%" stop-color="var(--violet)"  />
      </linearGradient>
    </defs>

    <!-- Hexagon outline — rotates 30° on hover -->
    <polygon
      points="12 2 21 7.2 21 16.8 12 22 3 16.8 3 7.2"
      fill="none"
      stroke="url(#logo-grad)"
      stroke-width="1.5"
      class="hex-outline"
    />

    <!-- Terminal >_ prompt centred in hexagon -->
    <text
      x="12"
      y="14.8"
      font-family="monospace"
      font-size="6.5"
      font-weight="bold"
      fill="var(--sky)"
      text-anchor="middle"
      class="prompt-text transition-colors duration-300"
    >&gt;_</text>
  </svg>

  {
    showDevLabel && (
      <span class="logo-wordmark font-mono text-xs tracking-[0.14em]">
        <span class="logo-azael transition-colors duration-300">azael</span>
        <span class="logo-dev grad-text font-bold">.dev</span>
      </span>
    )
  }
</span>

<style>
  /* ── Wordmark layout ── */
  .logo-wordmark {
    display: inline-flex;
    align-items: baseline;
    gap: 0;
    transition: opacity 0.3s ease;
  }

  /* ── "azael" colour ── */
  .logo-azael {
    color: rgba(224, 234, 255, 0.85);
  }

  .logo-root:hover .logo-azael {
    color: rgba(224, 234, 255, 1);
  }

  /* ── Hexagon hover: 30° rotation ── */
  .hex-outline {
    transform-origin: 12px 12px;
    transition: transform 0.5s ease, stroke-opacity 0.3s ease;
  }

  .logo-root:hover .hex-outline {
    transform: rotate(30deg);
  }

  /* ── Prompt hover colour ── */
  .logo-root:hover .prompt-text {
    fill: var(--violet);
  }

  /* ── Glitch chromatic aberration on hover (one-shot) ── */
  @keyframes glitch {
    0%,100% { filter: drop-shadow(0 0 6px rgba(56,189,248,.55)); transform: translate(0,0); }
    20%     { filter: drop-shadow(-2px 0 0 #f87171) drop-shadow(2px 0 0 #38bdf8); transform: translate(-1px,0); }
    40%     { filter: drop-shadow(2px 0 0 #a78bfa) drop-shadow(-2px 0 0 #38bdf8); transform: translate(1px,-1px); }
    60%     { filter: drop-shadow(0 0 8px rgba(167,139,250,.6)); transform: translate(0,0); }
  }

  .logo-root:hover .glitch-svg {
    animation: glitch 0.45s step-end 1;
  }

  /* ── Glow at rest ── */
  .logo-root:not(:hover) .logo-svg {
    filter: none;
    transition: filter 0.3s ease;
  }

  /* ── Light mode overrides ── */
  :global([data-theme="light"]) .logo-azael {
    color: #0f172a;
  }

  :global([data-theme="light"]) .logo-root:hover .logo-azael {
    color: #0f172a;
  }

  :global([data-theme="light"]) .logo-svg {
    filter: drop-shadow(0 2px 4px rgba(0, 0, 0, 0.12));
  }
</style>
