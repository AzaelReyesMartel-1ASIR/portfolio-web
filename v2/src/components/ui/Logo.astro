---
interface Props {
  className?: string;
  ariaLabel?: string;
  showDevLabel?: boolean;
}

const {
  className = "",
  ariaLabel = "Logo de Azael Reyes",
  showDevLabel = true,
} = Astro.props;
---

<!-- [ASTRO: Logo.astro] -->
<span class={`logo-root inline-flex items-center gap-2 ${className}`} aria-label={ariaLabel}>
  <!--
    Pixel-art heart with clock circle + >_ prompt.
    The gradient is applied via a <mask> so the entire shape
    reads the gradient uniformly instead of per-rect.
  -->
  <svg
    xmlns="http://www.w3.org/2000/svg"
    viewBox="0 0 20 16"
    shape-rendering="crispEdges"
    role="img"
    aria-hidden="true"
    class="logo-svg h-[28px] w-[34px]"
  >
    <defs>
      <!-- Sky → Violet diagonal gradient over the whole icon -->
      <linearGradient id="logo-grad" x1="0%" y1="0%" x2="100%" y2="100%">
        <stop offset="0%"   stop-color="var(--sky)"    />
        <stop offset="100%" stop-color="var(--violet)"  />
      </linearGradient>

      <!--
        The mask: white pixels = visible, black/absent = hidden.
        This is the full pixel-art of the heart + >_ prompt.
        The clock circle "cutout" is black (absent) to let the
        background show through, creating a hollow-ring effect.
      -->
      <mask id="heart-mask">
        <!-- Heart body -->
        <rect x="3"  y="0"  width="4"  height="1" fill="white" />
        <rect x="9"  y="0"  width="2"  height="1" fill="white" />
        <rect x="13" y="0"  width="4"  height="1" fill="white" />
        <rect x="1"  y="1"  width="6"  height="1" fill="white" />
        <rect x="8"  y="1"  width="4"  height="1" fill="white" />
        <rect x="13" y="1"  width="6"  height="1" fill="white" />
        <rect x="0"  y="2"  width="20" height="1" fill="white" />
        <rect x="0"  y="3"  width="20" height="1" fill="white" />
        <rect x="0"  y="4"  width="20" height="1" fill="white" />
        <rect x="1"  y="5"  width="18" height="1" fill="white" />
        <rect x="1"  y="6"  width="18" height="1" fill="white" />
        <rect x="2"  y="7"  width="16" height="1" fill="white" />
        <rect x="3"  y="8"  width="14" height="1" fill="white" />
        <rect x="4"  y="9"  width="12" height="1" fill="white" />
        <rect x="5"  y="10" width="10" height="1" fill="white" />
        <rect x="6"  y="11" width="8"  height="1" fill="white" />
        <rect x="7"  y="12" width="6"  height="1" fill="white" />
        <rect x="8"  y="13" width="4"  height="1" fill="white" />
        <rect x="9"  y="14" width="2"  height="1" fill="white" />

        <!-- Clock-sphere ring: carve out a hollow circle (black = transparent) -->
        <rect x="9"  y="3"  width="2"  height="1" fill="black" />
        <rect x="8"  y="4"  width="1"  height="1" fill="black" />
        <rect x="11" y="4"  width="1"  height="1" fill="black" />
        <rect x="7"  y="5"  width="1"  height="3" fill="black" />
        <rect x="12" y="5"  width="1"  height="3" fill="black" />
        <rect x="8"  y="8"  width="1"  height="1" fill="black" />
        <rect x="11" y="8"  width="1"  height="1" fill="black" />
        <rect x="9"  y="8"  width="2"  height="1" fill="black" />

        <!-- >_ prompt INSIDE the circle (white = visible over gradient) -->
        <!-- ">" chevron -->
        <rect x="8"  y="5"  width="1"  height="1" fill="white" />
        <rect x="9"  y="6"  width="1"  height="1" fill="white" />
        <rect x="8"  y="7"  width="1"  height="1" fill="white" />
        <!-- "_" underscore -->
        <rect x="10" y="7"  width="2"  height="1" fill="white" />
      </mask>
    </defs>

    <!-- Single gradient rect revealed through the mask — true uniform gradient -->
    <rect width="20" height="16" fill="url(#logo-grad)" mask="url(#heart-mask)" />
  </svg>

  {
    showDevLabel && (
      <span class="logo-wordmark font-mono text-xs tracking-[0.14em]">
        <span class="logo-azael">azael</span><span class="logo-dev grad-text font-bold">.dev</span>
      </span>
    )
  }
</span>

<style>
  /* ── Logo SVG glow on parent hover ── */
  .logo-root:hover .logo-svg {
    filter: drop-shadow(0 0 6px rgba(56, 189, 248, 0.55));
    transition: filter 0.3s ease;
  }

  /* "azael" — subtle shimmer matching the .dev gradient timing */
  .logo-azael {
    color: rgba(224, 234, 255, 0.85);
    transition: color 0.3s ease;
  }

  .logo-root:hover .logo-azael {
    color: rgba(224, 234, 255, 1);
  }

  /* Wordmark transition */
  .logo-wordmark {
    display: inline-flex;
    align-items: baseline;
    gap: 0;
    transition: opacity 0.3s ease;
  }

  /* Light mode overrides */
  :global([data-theme="light"]) .logo-azael {
    color: rgba(15, 23, 55, 0.85);
  }

  :global([data-theme="light"]) .logo-root:hover .logo-azael {
    color: rgba(15, 23, 55, 1);
  }
</style>
