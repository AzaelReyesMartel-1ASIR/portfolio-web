---
import type { ProjectItem } from "../../data/projects";

interface Props {
  project: ProjectItem;
  index?: number;
}

const { project, index = 0 } = Astro.props as Props;

const accentClassMap: Record<ProjectItem["accent"], string> = {
  sky: "project-accent-sky",
  violet: "project-accent-violet",
  green: "project-accent-green",
};

const delayClassMap = ["rd1", "rd2", "rd3", "rd4"] as const;
const revealDelayClass = delayClassMap[index % delayClassMap.length];
---

<!-- [ASTRO: ProjectCard.astro] -->
<article
  class={`project-card project-spotlight reveal ${revealDelayClass} ${accentClassMap[project.accent]}`}
  aria-label={`Proyecto ${project.title}`}
>
  <div class="project-card__top">
    <p class="font-mono text-[0.68rem] uppercase tracking-[0.18em] text-sky/90">proyecto</p>
    {project.featured && (
      <span class="project-featured-badge" aria-label="Proyecto destacado">
        FEATURED
      </span>
    )}
  </div>

  <h3 class="mt-4 font-display text-2xl leading-tight text-ink">{project.title}</h3>
  <p class="mt-4 text-sm leading-6 text-muted">{project.description}</p>

  <ul class="mt-5 flex flex-wrap gap-2" aria-label={`Stack usado en ${project.title}`}>
    {project.stack.map((item) => (
      <li class="project-tag">{item}</li>
    ))}
  </ul>

  <a
    href={project.githubUrl}
    target="_blank"
    rel="noreferrer noopener"
    class="project-link mt-7 inline-flex items-center gap-2 font-mono text-[0.72rem] uppercase tracking-[0.16em]"
    aria-label={`Abrir repositorio de ${project.title} en GitHub`}
  >
    <span>Ver código</span>
    <span aria-hidden="true">↗</span>
  </a>
</article>

<style>
  .project-card {
    position: relative;
    overflow: hidden;
    border: 1px solid var(--border);
    border-radius: 20px;
    padding: 1.25rem;
    background: rgba(12, 21, 48, 0.74);
    backdrop-filter: blur(8px);
    isolation: isolate;
    transition: transform 0.28s ease, border-color 0.28s ease;
  }

  .project-card:hover {
    transform: translateY(-4px);
  }

  .project-card::before {
    content: "";
    position: absolute;
    inset: 0;
    z-index: 0;
    pointer-events: none;
    opacity: 0;
    transition: opacity 0.24s ease;
    background: radial-gradient(
      320px circle at var(--spot-x, 50%) var(--spot-y, 50%),
      rgba(255, 255, 255, 0.16),
      transparent 65%
    );
  }

  .project-card:hover::before {
    opacity: 1;
  }

  .project-card > * {
    position: relative;
    z-index: 1;
  }

  .project-card__top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
  }

  .project-featured-badge {
    border: 1px solid rgba(56, 189, 248, 0.32);
    border-radius: 999px;
    background: rgba(56, 189, 248, 0.14);
    padding: 0.3rem 0.56rem;
    font-family: var(--font-mono);
    font-size: 0.62rem;
    letter-spacing: 0.14em;
    color: #67ceff;
  }

  .project-tag {
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.02);
    padding: 0.28rem 0.58rem;
    font-family: var(--font-mono);
    font-size: 0.68rem;
    color: #b8c7e8;
  }

  .project-link {
    color: #9adfff;
    text-decoration: none;
    transition: color 0.2s ease;
  }

  .project-link:hover {
    color: #c9edff;
  }

  .project-accent-sky {
    border-color: rgba(56, 189, 248, 0.22);
  }

  .project-accent-violet {
    border-color: rgba(167, 139, 250, 0.24);
  }

  .project-accent-green {
    border-color: rgba(52, 211, 153, 0.24);
  }
</style>
