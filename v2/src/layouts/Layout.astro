---
import Footer from "../components/layout/Footer.astro";
import Header from "../components/layout/Header.astro";
import Cursor from "../components/ui/Cursor.astro";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Azael Reyes Martel — Software Engineer",
  description = "Portfolio profesional de Azael Reyes Martel: Backend, SysAdmin, Docker y Laravel.",
} = Astro.props;

import "../styles/global.css";
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <title>{title}</title>
  </head>
  <body>
    <Header />
    <Cursor />
    <slot />
    <Footer />
    <button
      id="back-to-top"
      type="button"
      class="magnetic fixed bottom-5 right-5 z-[950] inline-flex h-11 w-11 items-center justify-center rounded-full border border-white/15 bg-card/90 text-sky opacity-0 shadow-[0_10px_24px_rgba(0,0,0,0.35)] transition-all duration-300 hover:border-sky/45"
      aria-label="Volver arriba"
    >
      <span aria-hidden="true" class="font-mono text-base">↑</span>
    </button>

    <script type="module">
      import { initHeader } from "../scripts/header.ts";
      import { initCursor } from "../scripts/cursor.ts";

      initHeader();
      initCursor();
    </script>
  </body>
</html>
