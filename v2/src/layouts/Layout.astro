---
import Footer from "../components/layout/Footer.astro";
import Header from "../components/layout/Header.astro";
import Cursor from "../components/ui/Cursor.astro";
import Background from "../components/ui/Background.astro";
import { ClientRouter as ViewTransitions } from "astro:transitions";
import { useTranslations } from "../i18n/utils";

interface Props {
    title?: string;
    description?: string;
    lang?: string;
}

const {
    title = "Azael Reyes Martel — Software Engineer",
    description = "Portfolio profesional de Azael Reyes Martel: Backend, SysAdmin, Docker y Laravel.",
    lang = "es",
} = Astro.props;

const t = useTranslations(lang as any);

import "../styles/global.css";
---

<!doctype html>
<html lang={lang}>
    <head>
        <meta charset="utf-8" />
        <script is:inline>
            const savedY = sessionStorage.getItem("langLockY");
            if (savedY) {
                const targetY = parseInt(savedY, 10);

                document.documentElement.style.scrollBehavior = "auto";

                const lockInterval = setInterval(() => {
                    window.scrollTo(0, targetY);
                }, 10);

                window.addEventListener("load", () => {
                    setTimeout(() => {
                        clearInterval(lockInterval);
                        sessionStorage.removeItem("langLockY");
                        document.documentElement.style.scrollBehavior = "";
                    }, 50);
                });
            }
        </script>
        <meta name="viewport" content="width=device-width, initial-scale=1" />
        <meta name="generator" content={Astro.generator} />
        <meta name="description" content={description} />
        <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
        <link rel="icon" href="/favicon.ico" />
        <title>{title}</title>
        <ViewTransitions />

        <!-- Three.js r134 + Vanta NET — 3D topology background -->
        <script
            src="https://cdnjs.cloudflare.com/ajax/libs/three.js/r134/three.min.js"
            defer></script>
        <script
            src="https://cdn.jsdelivr.net/npm/vanta@latest/dist/vanta.net.min.js"
            defer></script>

        <noscript>
            <style>
                /* Instantly show all reveal elements since scroll scripts won't run */
                .reveal {
                    opacity: 1 !important;
                    transform: none !important;
                }
                /* Hide JS-dependent interactive contact form since it can't execute fetch */
                #contact-form {
                    display: none !important;
                }
                /* Disable custom cursor, trailing effects, and back-to-top button */
                #cursor-dot,
                #cursor-outline,
                .c-trail,
                #back-to-top {
                    display: none !important;
                }
                body {
                    cursor: auto !important;
                }
                a, button, input, textarea, select, [role="button"], .cursor-pointer {
                    cursor: pointer !important;
                }
                html {
                    scroll-padding-top: 7.5rem !important;
                }
            </style>
        </noscript>
    </head>
    <body>
        <a href="#main-content" class="skip-link font-mono">{t('nav.skip')}</a>
        <!-- Apply theme before first paint to prevent FOUC -->
        <script is:inline>
            (function () {
                var stored = localStorage.getItem("theme");
                var preferLight = window.matchMedia(
                    "(prefers-color-scheme: light)",
                ).matches;
                var theme =
                    stored === "light" || stored === "dark"
                        ? stored
                        : preferLight
                          ? "light"
                          : "dark";
                if (theme === "light") {
                    document.documentElement.setAttribute(
                        "data-theme",
                        "light",
                    );
                }
            })();
        </script>
        <!-- Vanta NET canvas layer (z-[-1], pointer-events-none) -->
        <div
            id="vanta-bg"
            class="pointer-events-none fixed inset-0 z-[-1]"
            aria-hidden="true"
        >
        </div>
        <Background />
        <!-- CRT / scanlines texture overlay -->
        <div
            class="crt-scanlines pointer-events-none fixed inset-0 z-[9998] mix-blend-overlay"
            style="background-image: repeating-linear-gradient(0deg, transparent, transparent 2px, #000 2px, #000 4px);"
            aria-hidden="true"
        >
        </div>
        <Header />
        <Cursor />
        <slot />
        <Footer />
        <!-- Back to top: visibility driven by JS (opacity + transform transition) -->
        <button
            id="back-to-top"
            type="button"
            class="btt-btn magnetic fixed bottom-6 right-6 z-[950] inline-flex h-11 w-11 items-center justify-center rounded-full border shadow-lg transition-all duration-300"
            aria-label="Volver arriba"
            style="opacity:0; transform:translateY(12px); pointer-events:none;"
        >
            <svg
                xmlns="http://www.w3.org/2000/svg"
                width="18"
                height="18"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2.2"
                stroke-linecap="round"
                stroke-linejoin="round"
                aria-hidden="true"
            >
                <path d="M18 15l-6-6-6 6"></path>
            </svg>
        </button>

        <!-- Vanta NET init — reactive: MutationObserver recalculates colors on theme change -->
        <script is:inline>
            (function () {
                var DARK = {
                    color: 0x38bdf8,
                    backgroundColor: 0x04081a,
                    maxDistance: 22,
                    spacing: 18,
                };
                var LIGHT = {
                    color: 0x0f172a,
                    backgroundColor: 0xf1f5f9,
                    maxDistance: 24,
                    spacing: 16,
                };

                var MOBILE_BREAKPOINT = 768;
                var tries = 0;
                var vantaEffect = null;

                function getThemeOptions() {
                    var isLight =
                        document.documentElement.getAttribute("data-theme") ===
                        "light";
                    return isLight ? LIGHT : DARK;
                }

                /** Apply static gradient fallback for mobile — zero GPU cost */
                function applyMobileFallback(el) {
                    var isLight =
                        document.documentElement.getAttribute("data-theme") ===
                        "light";
                    el.style.background = isLight
                        ? "linear-gradient(135deg, #f1f5f9 0%, #e2e8f0 50%, #f1f5f9 100%)"
                        : "linear-gradient(135deg, #04081a 0%, #0c1530 40%, #04081a 100%)";
                }

                function initVanta() {
                    tries++;

                    /* ── KILL-SWITCH: no WebGL on mobile ── */
                    var el = document.getElementById("vanta-bg");
                    if (!el) return;

                    if (window.innerWidth < MOBILE_BREAKPOINT || matchMedia('(pointer:coarse)').matches) {
                        applyMobileFallback(el);
                        /* Listen for theme changes even on mobile to swap gradient */
                        var mobileObs = new MutationObserver(function () {
                            applyMobileFallback(el);
                        });
                        mobileObs.observe(document.documentElement, {
                            attributes: true,
                            attributeFilter: ["data-theme"],
                        });
                        return; /* ← never touch VANTA on mobile */
                    }

                    if (
                        typeof window.VANTA === "undefined" ||
                        typeof window.THREE === "undefined"
                    ) {
                        if (tries < 60) requestAnimationFrame(initVanta);
                        return;
                    }

                    var opts = getThemeOptions();
                    vantaEffect = window.VANTA.NET({
                        el: el,
                        THREE: window.THREE,
                        mouseControls: true,
                        touchControls: false,
                        gyroControls: false,
                        minHeight: 200,
                        minWidth: 200,
                        scale: 1.0,
                        scaleMobile: 1.0,
                        color: opts.color,
                        backgroundColor: opts.backgroundColor,
                        points: 12,
                        maxDistance: opts.maxDistance,
                        spacing: opts.spacing,
                        showDots: true,
                    });

                    /* ── Reactive theme observer ── */
                    var observer = new MutationObserver(function (mutations) {
                        mutations.forEach(function (m) {
                            if (
                                m.attributeName === "data-theme" &&
                                vantaEffect
                            ) {
                                var next = getThemeOptions();
                                vantaEffect.setOptions({
                                    color: next.color,
                                    backgroundColor: next.backgroundColor,
                                    maxDistance: next.maxDistance,
                                    spacing: next.spacing,
                                });
                            }
                        });
                    });
                    observer.observe(document.documentElement, {
                        attributes: true,
                        attributeFilter: ["data-theme"],
                    });
                }

                // Initial load binding
                if (document.readyState === "complete") {
                    requestAnimationFrame(initVanta);
                } else {
                    window.addEventListener("load", function () {
                        requestAnimationFrame(initVanta);
                    });
                }

                // Transition swap binding (Astro ClientRouter)
                document.addEventListener("astro:page-load", function () {
                    if (vantaEffect && typeof vantaEffect.destroy === "function") {
                        try {
                            vantaEffect.destroy();
                        } catch (err) {
                            console.error("Vanta destroy error:", err);
                        }
                        vantaEffect = null;
                    }
                    tries = 0;
                    requestAnimationFrame(initVanta);
                });
            })();
        </script>

        <script>
            import { initHeader } from "../scripts/header.ts";
            import { initCursor } from "../scripts/cursor.ts";
            import { initTerminal } from "../scripts/terminal.ts";
            import { initTypewriter } from "../scripts/typewriter.ts";

            const initAll = () => {
                initHeader();
                initCursor();
                initTerminal();
                initTypewriter();
            };

            // Initialize on initial page load and on subsequent View Transition swaps
            document.addEventListener("astro:page-load", initAll);
        </script>

        <style>
            /* Dark mode (default) */
            .btt-btn {
                background: rgba(12, 21, 48, 0.88);
                border-color: rgba(255, 255, 255, 0.12);
                color: #38bdf8;
                backdrop-filter: blur(8px);
            }

            .btt-btn:hover {
                border-color: rgba(56, 189, 248, 0.45);
                background: rgba(12, 21, 48, 0.98);
                box-shadow:
                    0 0 18px rgba(56, 189, 248, 0.22),
                    0 10px 28px rgba(0, 0, 0, 0.4);
            }

            /* Light mode */
            :global([data-theme="light"]) .btt-btn {
                background: #ffffff;
                border-color: rgba(0, 0, 0, 0.1);
                color: #0ea5e9;
                box-shadow: 0 4px 16px rgba(0, 0, 0, 0.1);
                backdrop-filter: none;
            }

            :global([data-theme="light"]) .btt-btn:hover {
                border-color: rgba(14, 165, 233, 0.5);
                background: #f0f9ff;
                box-shadow:
                    0 0 18px rgba(14, 165, 233, 0.2),
                    0 6px 20px rgba(0, 0, 0, 0.1);
            }

            /* ── skip link styling ── */
            .skip-link {
                position: fixed;
                top: 1rem;
                left: 50%;
                transform: translate(-50%, -200%);
                z-index: 10002;
                padding: 0.75rem 1.5rem;
                background: rgba(12, 21, 48, 0.92);
                border: 1px solid rgba(56, 189, 248, 0.35);
                color: #38bdf8;
                border-radius: 9999px;
                font-weight: 500;
                font-size: 0.85rem;
                text-decoration: none;
                box-shadow: 
                    0 0 20px rgba(56, 189, 248, 0.2),
                    0 12px 32px rgba(0, 0, 0, 0.5);
                backdrop-filter: blur(8px);
                transition: transform 0.3s cubic-bezier(0.16, 1, 0.3, 1), border-color 0.2s, box-shadow 0.2s;
            }
            .skip-link:focus, .skip-link:focus-visible {
                transform: translate(-50%, 0);
                outline: none;
                border-color: #38bdf8;
                box-shadow: 
                    0 0 30px rgba(56, 189, 248, 0.35),
                    0 12px 32px rgba(0, 0, 0, 0.6);
            }
            :global([data-theme="light"]) .skip-link {
                background: rgba(255, 255, 255, 0.95);
                border-color: rgba(14, 165, 233, 0.25);
                color: #0ea5e9;
                box-shadow: 
                    0 0 20px rgba(14, 165, 233, 0.1),
                    0 12px 32px rgba(0, 0, 0, 0.08);
            }
            :global([data-theme="light"]) .skip-link:focus, :global([data-theme="light"]) .skip-link:focus-visible {
                border-color: #0ea5e9;
                box-shadow: 
                    0 0 30px rgba(14, 165, 233, 0.2),
                    0 12px 32px rgba(0, 0, 0, 0.12);
            }
        </style>
        <!-- Kill-switch: desactiva efectos GPU pesados cuando devicePixelRatio > 1.5 (zoom o pantalla HiDPI) -->
        <script is:inline>
            (function () {
                function checkZoom() {
                    if (window.devicePixelRatio > 1.25) {
                        document.body.classList.add("low-power-mode");
                    } else {
                        document.body.classList.remove("low-power-mode");
                    }
                }
                window.addEventListener("resize", checkZoom);
                checkZoom();
            })();
        </script>
    </body>
</html>
