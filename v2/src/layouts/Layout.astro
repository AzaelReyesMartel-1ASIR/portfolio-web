---
interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Azael Reyes Martel — Software Engineer",
  description = "Portfolio profesional de Azael Reyes Martel: Backend, SysAdmin, Docker y Laravel.",
} = Astro.props;

import "../styles/global.css";
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <title>{title}</title>
  </head>
  <body>
    <slot />
  </body>
</html>
