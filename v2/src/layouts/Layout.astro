---
import Footer from "../components/layout/Footer.astro";
import Header from "../components/layout/Header.astro";
import Cursor from "../components/ui/Cursor.astro";
import Background from "../components/ui/Background.astro";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Azael Reyes Martel — Software Engineer",
  description = "Portfolio profesional de Azael Reyes Martel: Backend, SysAdmin, Docker y Laravel.",
} = Astro.props;

import "../styles/global.css";
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <title>{title}</title>

    <!-- Three.js r134 + Vanta NET — 3D topology background -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/three.js/r134/three.min.js" defer></script>
    <script src="https://cdn.jsdelivr.net/npm/vanta@latest/dist/vanta.net.min.js" defer></script>
  </head>
  <body>
    <!-- Apply theme before first paint to prevent FOUC -->
    <script is:inline>
      (function () {
        var stored = localStorage.getItem('theme');
        var preferLight = window.matchMedia('(prefers-color-scheme: light)').matches;
        var theme = stored === 'light' || stored === 'dark'
          ? stored
          : (preferLight ? 'light' : 'dark');
        if (theme === 'light') {
          document.documentElement.setAttribute('data-theme', 'light');
        }
      })();
    </script>
    <!-- Vanta NET canvas layer (z-[-1], pointer-events-none) -->
    <div id="vanta-bg" class="pointer-events-none fixed inset-0 z-[-1]" aria-hidden="true"></div>
    <Background />
    <Header />
    <Cursor />
    <slot />
    <Footer />
    <!-- Back to top: visibility driven by JS (opacity + transform transition) -->
    <button
      id="back-to-top"
      type="button"
      class="btt-btn magnetic fixed bottom-6 right-6 z-[950] inline-flex h-11 w-11 items-center justify-center rounded-full border shadow-lg transition-all duration-300"
      aria-label="Volver arriba"
      style="opacity:0; transform:translateY(12px); pointer-events:none;"
    >
      <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M18 15l-6-6-6 6"/>
      </svg>
    </button>

    <!-- Vanta NET init — reactive: MutationObserver recalculates colors on theme change -->
    <script is:inline>
      (function () {
        var DARK  = { color: 0x38bdf8, backgroundColor: 0x04081a, maxDistance: 22, spacing: 18 };
        var LIGHT = { color: 0x0f172a, backgroundColor: 0xf1f5f9, maxDistance: 24, spacing: 16 };

        var tries = 0;
        var vantaEffect = null;

        function getThemeOptions() {
          var isLight = document.documentElement.getAttribute('data-theme') === 'light';
          return isLight ? LIGHT : DARK;
        }

        function initVanta() {
          tries++;
          if (typeof window.VANTA === 'undefined' || typeof window.THREE === 'undefined') {
            if (tries < 60) requestAnimationFrame(initVanta);
            return;
          }
          var el = document.getElementById('vanta-bg');
          if (!el) return;

          var opts = getThemeOptions();
          vantaEffect = window.VANTA.NET({
            el: el,
            THREE: window.THREE,
            mouseControls: true,
            touchControls: false,
            gyroControls: false,
            minHeight: 200,
            minWidth: 200,
            scale: 1.00,
            scaleMobile: 1.00,
            color: opts.color,
            backgroundColor: opts.backgroundColor,
            points: 12,
            maxDistance: opts.maxDistance,
            spacing: opts.spacing,
            showDots: true
          });

          /* ── Reactive theme observer ── */
          var observer = new MutationObserver(function (mutations) {
            mutations.forEach(function (m) {
              if (m.attributeName === 'data-theme' && vantaEffect) {
                var next = getThemeOptions();
                vantaEffect.setOptions({
                  color: next.color,
                  backgroundColor: next.backgroundColor,
                  maxDistance: next.maxDistance,
                  spacing: next.spacing
                });
              }
            });
          });
          observer.observe(document.documentElement, { attributes: true, attributeFilter: ['data-theme'] });
        }

        window.addEventListener('load', function () { requestAnimationFrame(initVanta); });
      })();
    </script>

    <script>
      import { initHeader }     from "../scripts/header.ts";
      import { initCursor }     from "../scripts/cursor.ts";
      import { initTerminal }   from "../scripts/terminal.ts";
      import { initTypewriter } from "../scripts/typewriter.ts";

      initHeader();
      initCursor();
      initTerminal();
      initTypewriter();
    </script>

    <style>
      /* Dark mode (default) */
      .btt-btn {
        background: rgba(12, 21, 48, 0.88);
        border-color: rgba(255, 255, 255, 0.12);
        color: #38bdf8;
        backdrop-filter: blur(8px);
      }

      .btt-btn:hover {
        border-color: rgba(56, 189, 248, 0.45);
        background: rgba(12, 21, 48, 0.98);
        box-shadow: 0 0 18px rgba(56, 189, 248, 0.22), 0 10px 28px rgba(0, 0, 0, 0.4);
      }

      /* Light mode */
      :global([data-theme="light"]) .btt-btn {
        background: #ffffff;
        border-color: rgba(0, 0, 0, 0.1);
        color: #0ea5e9;
        box-shadow: 0 4px 16px rgba(0, 0, 0, 0.1);
        backdrop-filter: none;
      }

      :global([data-theme="light"]) .btt-btn:hover {
        border-color: rgba(14, 165, 233, 0.5);
        background: #f0f9ff;
        box-shadow: 0 0 18px rgba(14, 165, 233, 0.2), 0 6px 20px rgba(0, 0, 0, 0.1);
      }
    </style>
  </body>
</html>
