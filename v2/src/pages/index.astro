---
import Layout from "../layouts/Layout.astro";
import Hero from "../components/sections/Hero.astro";
import About from "../components/sections/About.astro";
import Skills from "../components/sections/Skills.astro";
import Projects from "../components/sections/Projects.astro";
---

<Layout
  title="Azael Reyes Martel — Portfolio"
  description="Portfolio profesional de Azael Reyes Martel, Software Engineer especializado en Backend, SysAdmin, Docker y Laravel."
>
  <main aria-label="Página principal del portfolio" class="pt-28">
    <Hero />
    <About />
    <Skills />
    <Projects />
    <section id="contacto" aria-label="Sección de contacto"></section>
  </main>

  <script type="module">
    import { initTerminal } from "../scripts/terminal.ts";
    import { initScramble } from "../scripts/scramble.ts";
    import { initReveal } from "../scripts/reveal.ts";
    import { initCounters } from "../scripts/counters.ts";
    import { initSpotlight } from "../scripts/spotlight.ts";

    initTerminal();
    initScramble();
    initReveal();
    initCounters();
    initSpotlight();
  </script>
</Layout>
